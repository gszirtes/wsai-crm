# wespeak.ai CRM — Environment Configuration
# Copy to .env and fill in real values:
#   cp .env.example .env

# --- Database ---
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=wespeak_crm

# --- Security (GENER THESE — do not use defaults in production) ---
# JWT secret:  python3 -c "import secrets; print(secrets.token_hex(48))"
JWT_SECRET=
# Fernet key:  python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# --- Admin account (seeded on first start only) ---
ADMIN_EMAIL=admin@wespeak.ai
ADMIN_PASSWORD=change_me

# --- Cookie security ---
# Set to false for local HTTP testing, true for production (HTTPS required)
COOKIE_SECURE=false

# --- Registration ---
# Set to true to allow self-registration (public sign-up). Default: false (admin creates users).
ALLOW_REGISTRATION=false

# --- Frontend URL (used for CORS + cookie domain) ---
# Local:      http://localhost:3000
# Production: https://crm.wespeak.ai
FRONTEND_URL=http://localhost:3000

# --- AI (optional — can also be set in-app via Settings) ---
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free

# --- MCP server (optional, Phase 6) ---
# The MCP server needs a service-account API key to call the CRM's REST API.
# Mint one from Settings > Service Accounts (admin only) once the app is
# running, then paste the raw key here (it's shown once, at creation time,
# and never retrievable again) and restart the mcp-server container. This
# same key doubles as the MCP server's own authentication -- an MCP client
# must send it back as an X-API-Key header, or every request is rejected.
# The mcp-server container only starts under the "mcp" Compose profile
# (`docker compose --profile mcp up -d --build mcp-server`), so leaving
# this blank and never using that profile is enough to skip it entirely.
CRM_MCP_API_KEY=
